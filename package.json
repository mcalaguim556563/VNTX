{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "spa:dev": "vite --config vite.spa.config.js",
        "spa:build": "vite build --config vite.spa.config.js",
        "server": "npm run dev --prefix backend",
        "dev:full": "concurrently \"npm run spa:dev\" \"npm run server\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "date-fns": "^4.1.0",
        "lucide-react": "^1.8.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router": "^7.14.1",
        "recharts": "^3.8.1"
    }
}
